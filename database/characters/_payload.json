[{"data":1,"prerenderedAt":263},["ShallowReactive",2],{"page-\u002Fdatabase\u002Fcharacters":3},{"id":4,"title":5,"body":6,"description":254,"extension":255,"meta":256,"navigation":257,"path":259,"seo":260,"stem":261,"__hash__":262},"content\u002Fdatabase\u002Fcharacters.md","캐릭터 도감",{"type":7,"value":8,"toc":248},"minimark",[9,13,20,25,145,149],[10,11,5],"h1",{"id":12},"캐릭터-도감",[14,15,16],"blockquote",{},[17,18,19],"p",{},"베타 기준 데이터입니다. 직업 밸런스는 지속적으로 조정됩니다.",[21,22,24],"h2",{"id":23},"플레이어-직업","플레이어 직업",[26,27,28,47],"table",{},[29,30,31],"thead",{},[32,33,34,38,41,44],"tr",{},[35,36,37],"th",{},"이름",[35,39,40],{},"직업",[35,42,43],{},"역할",[35,45,46],{},"특성",[48,49,50,65,79,92,106,119,132],"tbody",{},[32,51,52,56,59,62],{},[53,54,55],"td",{},"검사",[53,57,58],{},"전사 계열",[53,60,61],{},"근거리 딜러 \u002F 탱커",[53,63,64],{},"높은 HP와 방어력, 강력한 단일 타격기 보유. 근접 전투에 특화.",[32,66,67,70,73,76],{},[53,68,69],{},"마법사",[53,71,72],{},"마법 계열",[53,74,75],{},"원거리 딜러",[53,77,78],{},"광역 마법 스킬 다수 보유. 유리 몸이나 최상급 딜 출력.",[32,80,81,84,87,89],{},[53,82,83],{},"궁수",[53,85,86],{},"민첩 계열",[53,88,75],{},[53,90,91],{},"높은 회피율과 치명타율. 지속 딜 안정적이며 이동 중 공격 가능.",[32,93,94,97,100,103],{},[53,95,96],{},"성직자",[53,98,99],{},"신성 계열",[53,101,102],{},"힐러 \u002F 서포터",[53,104,105],{},"강력한 회복 및 버프 스킬. 파티 생존율을 크게 향상시킴.",[32,107,108,111,113,116],{},[53,109,110],{},"암살자",[53,112,86],{},[53,114,115],{},"근거리 딜러",[53,117,118],{},"은신 기술과 치명타 특화. 단일 타겟 순간 딜이 직업 중 최고.",[32,120,121,124,126,129],{},[53,122,123],{},"소환사",[53,125,72],{},[53,127,128],{},"서포터 \u002F 딜러",[53,130,131],{},"소환수를 통한 간접 전투. 다양한 속성 소환수로 상황 대응 가능.",[32,133,134,137,139,142],{},[53,135,136],{},"기사",[53,138,58],{},[53,140,141],{},"탱커",[53,143,144],{},"파티원 보호 스킬 다수 보유. 적의 어그로를 집중시키는 도발 전문.",[21,146,148],{"id":147},"주요-npc","주요 NPC",[26,150,151,163],{},[29,152,153],{},[32,154,155,157,159,161],{},[35,156,37],{},[35,158,40],{},[35,160,43],{},[35,162,46],{},[48,164,165,179,192,206,220,234],{},[32,166,167,170,173,176],{},[53,168,169],{},"에리온 왕",[53,171,172],{},"왕족",[53,174,175],{},"주요 의뢰 발행자",[53,177,178],{},"일랜시아 왕국의 군주. 초반 메인 퀘스트 의뢰자.",[32,180,181,184,186,189],{},[53,182,183],{},"대마법사 셀리스",[53,185,69],{},[53,187,188],{},"마법 길드 마스터",[53,190,191],{},"마법 스킬 고급 퀘스트 담당. 전설 지팡이 제작 레시피 보유.",[32,193,194,197,200,203],{},[53,195,196],{},"대장장이 고르",[53,198,199],{},"장인",[53,201,202],{},"제작 NPC",[53,204,205],{},"고급 장비 제작 및 강화 서비스 제공. 희귀 레시피 판매.",[32,207,208,211,214,217],{},[53,209,210],{},"숲의 정령 아르나",[53,212,213],{},"정령",[53,215,216],{},"비밀 퀘스트 NPC",[53,218,219],{},"달의 신전 입장 조건 퀘스트 제공. 정령 계열 아이템 거래.",[32,221,222,225,228,231],{},[53,223,224],{},"용병 대장 보르크",[53,226,227],{},"전사",[53,229,230],{},"파티 모집 NPC",[53,232,233],{},"솔로 플레이어를 위한 호위 용병 파견 서비스 운영.",[32,235,236,239,242,245],{},[53,237,238],{},"상인 라피",[53,240,241],{},"상인",[53,243,244],{},"특수 아이템 판매",[53,246,247],{},"이벤트 아이템 및 희귀 소비 아이템 한정 판매. 위치 이동형 NPC.",{"title":249,"searchDepth":250,"depth":250,"links":251},"",2,[252,253],{"id":23,"depth":250,"text":24},{"id":147,"depth":250,"text":148},"일랜시아에 등장하는 플레이어 직업 및 주요 NPC 캐릭터 정보를 정리한 도감입니다.","md",{},{"title":258},"캐릭터","\u002Fdatabase\u002Fcharacters",{"title":5,"description":254},"database\u002Fcharacters","XxSIDtjosVQjQlwOdYlVCqDzkg3BfjLZKwhmnwjr1y4",1781586027123]