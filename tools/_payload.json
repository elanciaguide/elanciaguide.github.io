[{"data":1,"prerenderedAt":105},["ShallowReactive",2],{"page-\u002Ftools":3},{"id":4,"title":5,"body":6,"description":96,"extension":97,"meta":98,"navigation":99,"path":101,"seo":102,"stem":103,"__hash__":104},"content\u002Ftools\u002Findex.md","인터랙티브 도구",{"type":7,"value":8,"toc":79},"minimark",[9,13,17,22,31,34,40,43,49,52,58,61,67,70,73],[10,11,5],"h1",{"id":12},"인터랙티브-도구",[14,15,16],"p",{},"일랜시아의 복잡한 스탯 시스템과 빌드 조합을 직접 시뮬레이션할 수 있는 도구 모음입니다. 현재 베타 서비스 중으로, 도구들은 순차적으로 추가될 예정입니다.",[18,19,21],"h2",{"id":20},"예정된-도구-목록","예정된 도구 목록",[23,24,26,27],"h3",{"id":25},"빌드-계산기-준비-중","빌드 계산기 ",[28,29,30],"code",{},"준비 중",[14,32,33],{},"클래스·스킬 조합을 선택하고 최종 스탯 합산치를 즉시 확인합니다. 장비 세트와 버프 조건을 반영한 실전 빌드 검토에 활용할 수 있습니다.",[23,35,37,38],{"id":36},"데미지-시뮬레이터-준비-중","데미지 시뮬레이터 ",[28,39,30],{},[14,41,42],{},"공격력, 크리티컬, 속성 저항 등 전투 변수를 입력해 예상 딜량을 계산합니다. 보스 공략 시 딜 검증 용도로 설계됩니다.",[23,44,46,47],{"id":45},"스탯-분배-도구-준비-중","스탯 분배 도구 ",[28,48,30],{},[14,50,51],{},"레벨업 시 포인트를 어디에 배분할지 시뮬레이션합니다. 목표 스탯에 도달하기 위한 최소 포인트 경로를 제안합니다.",[23,53,55,56],{"id":54},"강화합성-확률-계산기-준비-중","강화·합성 확률 계산기 ",[28,57,30],{},[14,59,60],{},"장비 강화 단계별 성공 확률과 기대 비용을 산출합니다. 재료 수급 계획을 세울 때 참고 자료로 활용할 수 있습니다.",[23,62,64,65],{"id":63},"파티-시너지-분석기-준비-중","파티 시너지 분석기 ",[28,66,30],{},[14,68,69],{},"파티 구성원의 클래스 조합을 입력하면 시너지 버프 적용 여부와 역할 밸런스를 분석합니다.",[71,72],"hr",{},[74,75,76],"blockquote",{},[14,77,78],{},"도구 개발 우선순위는 커뮤니티 피드백을 반영해 조정됩니다. 필요한 도구가 있다면 의견을 남겨주세요.",{"title":80,"searchDepth":81,"depth":81,"links":82},"",2,[83],{"id":20,"depth":81,"text":21,"children":84},[85,88,90,92,94],{"id":25,"depth":86,"text":87},3,"빌드 계산기 준비 중",{"id":36,"depth":86,"text":89},"데미지 시뮬레이터 준비 중",{"id":45,"depth":86,"text":91},"스탯 분배 도구 준비 중",{"id":54,"depth":86,"text":93},"강화·합성 확률 계산기 준비 중",{"id":63,"depth":86,"text":95},"파티 시너지 분석기 준비 중","일랜시아 빌드 설계와 전투 분석을 위한 계산기·시뮬레이터 모음","md",{},{"title":100},"도구","\u002Ftools",{"title":5,"description":96},"tools\u002Findex","Fu4EMU0e_OLKlj98nLZEf2c2c1qF4rvasWimonk9fEo",1781586027056]