[{"data":1,"prerenderedAt":360},["ShallowReactive",2],{"page-\u002Fsystems\u002Fprogression":3},{"id":4,"title":5,"body":6,"description":351,"extension":352,"meta":353,"navigation":354,"path":356,"seo":357,"stem":358,"__hash__":359},"content\u002Fsystems\u002Fprogression.md","성장과 레벨",{"type":7,"value":8,"toc":337},"minimark",[9,13,17,22,25,54,58,65,117,121,134,188,193,219,223,235,239,259,263,324],[10,11,5],"h1",{"id":12},"성장과-레벨",[14,15,16],"p",{},"일랜시아에서 캐릭터 성장은 레벨, 스탯, 장비 세 가지 축으로 이루어집니다. 세 요소를 균형 있게 키워야 후반 콘텐츠에서 효과적으로 활동할 수 있습니다.",[18,19,21],"h2",{"id":20},"경험치-획득","경험치 획득",[14,23,24],{},"경험치(EXP)는 다음 활동을 통해 획득합니다.",[26,27,28,36,42,48],"ul",{},[29,30,31,35],"li",{},[32,33,34],"strong",{},"몬스터 처치:"," 레벨 차이가 클수록 획득 경험치가 감소합니다. 캐릭터 레벨 ±5 범위의 몬스터가 효율적입니다.",[29,37,38,41],{},[32,39,40],{},"퀘스트 완료:"," 메인 퀘스트는 다량의 경험치와 함께 스토리 보상을 제공합니다.",[29,43,44,47],{},[32,45,46],{},"던전 클리어:"," 파티 플레이 시 보너스 경험치 20%가 적용됩니다.",[29,49,50,53],{},[32,51,52],{},"일일 임무:"," 매일 리셋되는 임무를 완료하면 소량의 경험치와 재화를 얻습니다.",[18,55,57],{"id":56},"레벨업-구조","레벨업 구조",[14,59,60,61,64],{},"현재 베타 기준 최대 레벨은 ",[32,62,63],{},"50","입니다.",[66,67,68,81],"table",{},[69,70,71],"thead",{},[72,73,74,78],"tr",{},[75,76,77],"th",{},"구간",[75,79,80],{},"특징",[82,83,84,93,101,109],"tbody",{},[72,85,86,90],{},[87,88,89],"td",{},"1~15",[87,91,92],{},"튜토리얼 구간. 퀘스트 위주로 빠르게 성장 가능",[72,94,95,98],{},[87,96,97],{},"16~30",[87,99,100],{},"스킬 트리 선택이 본격화됨. 파티 던전 개방",[72,102,103,106],{},[87,104,105],{},"31~45",[87,107,108],{},"경험치 요구량 급증. 일일 임무 병행 권장",[72,110,111,114],{},[87,112,113],{},"46~50",[87,115,116],{},"엔드게임 구간. 고급 레이드 및 거래소 콘텐츠",[18,118,120],{"id":119},"스탯-배분","스탯 배분",[14,122,123,124,127,128,133],{},"레벨업 시 스탯 포인트 ",[32,125,126],{},"5점","을 획득합니다. 초기화 비용은 ",[129,130,132],"a",{"href":131},"\u002Fsystems\u002Feconomy","재화와 경제","를 참고하세요.",[66,135,136,146],{},[69,137,138],{},[72,139,140,143],{},[75,141,142],{},"스탯",[75,144,145],{},"주요 효과",[82,147,148,156,164,172,180],{},[72,149,150,153],{},[87,151,152],{},"힘(STR)",[87,154,155],{},"물리 공격력, 최