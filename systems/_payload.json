[{"data":1,"prerenderedAt":148},["ShallowReactive",2],{"page-\u002Fsystems":3},{"id":4,"title":5,"body":6,"description":140,"extension":141,"meta":142,"navigation":143,"path":144,"seo":145,"stem":146,"__hash__":147},"content\u002Fsystems\u002Findex.md","게임 시스템",{"type":7,"value":8,"toc":134},"minimark",[9,13,17,22,86,90,93,125],[10,11,5],"h1",{"id":12},"게임-시스템",[14,15,16],"p",{},"일랜시아는 다양한 시스템이 유기적으로 연결된 MMORPG입니다. 베타 단계인 현재도 핵심 메커니즘은 안정적으로 운영되고 있으며, 아래 각 시스템 가이드를 통해 게임을 효율적으로 즐길 수 있습니다.",[18,19,21],"h2",{"id":20},"시스템-목록","시스템 목록",[23,24,25,41],"table",{},[26,27,28],"thead",{},[29,30,31,35,38],"tr",{},[32,33,34],"th",{},"시스템",[32,36,37],{},"요약",[32,39,40],{},"링크",[42,43,44,60,73],"tbody",{},[29,45,46,50,53],{},[47,48,49],"td",{},"전투 시스템",[47,51,52],{},"공격, 방어, 스킬, 상태이상 메커니즘",[47,54,55],{},[56,57,59],"a",{"href":58},"\u002Fsystems\u002Fcombat","바로가기",[29,61,62,65,68],{},[47,63,64],{},"성장과 레벨",[47,66,67],{},"경험치 획득, 레벨업, 스탯 배분, 장비 강화",[47,69,70],{},[56,71,59],{"href":72},"\u002Fsystems\u002Fprogression",[29,74,75,78,81],{},[47,76,77],{},"재화와 경제",[47,79,80],{},"화폐 종류, 상점, 거래소 이용법",[47,82,83],{},[56,84,59],{"href":85},"\u002Fsystems\u002Feconomy",[18,87,89],{"id":88},"시스템-간-연계","시스템 간 연계",[14,91,92],{},"일랜시아의 시스템은 독립적으로 작동하지 않습니다.",[94,95,96,108,122],"ul",{},[97,98,99,103,104,107],"li",{},[100,101,102],"strong",{},"전투"," 효율은 ",[100,105,106],{},"성장"," 수준(레벨·스탯·장비)에 직접 영향을 받습니다.",[97,109,110,113,114,117,118,121],{},[100,111,112],{},"경제"," 활동으로 얻은 재화는 ",[100,115,116],{},"장비 강화"," 및 ",[100,119,120],{},"소모품 구매","에 사용됩니다.",[97,123,124],{},"레벨이 오를수록 고급 던전과 거래소 아이템에 접근 가능합니다.",[126,127,128],"blockquote",{},[14,129,130,133],{},[100,131,132],{},"베타 안내:"," 일부 수치와 시스템 세부 사항은 정식 출시 전까지 변경될 수 있습니다.",{"title":135,"searchDepth":136,"depth":136,"links":137},"",2,[138,139],{"id":20,"depth":136,"text":21},{"id":88,"depth":136,"text":89},"일랜시아의 핵심 게임 시스템 전반을 소개하는 카테고리 개요입니다.","md",{},{"title":34},"\u002Fsystems",{"title":5,"description":140},"systems\u002Findex","MAdoUIBU2yM5KFGcDD3Tn8RhI