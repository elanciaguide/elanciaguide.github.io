[{"data":1,"prerenderedAt":295},["ShallowReactive",2],{"page-\u002Fsystems\u002Fcombat":3},{"id":4,"title":5,"body":6,"description":286,"extension":287,"meta":288,"navigation":289,"path":291,"seo":292,"stem":293,"__hash__":294},"content\u002Fsystems\u002Fcombat.md","전투 시스템",{"type":7,"value":8,"toc":273},"minimark",[9,13,17,22,25,106,110,113,136,140,143,148,168,172,175,178,181,251,260,264],[10,11,5],"h1",{"id":12},"전투-시스템",[14,15,16],"p",{},"일랜시아의 전투는 실시간 액션과 전략적 스킬 운용이 결합된 방식입니다. 단순한 자동 공격만으로는 고난도 콘텐츠를 클리어하기 어려우며, 타이밍과 스킬 조합이 핵심입니다.",[18,19,21],"h2",{"id":20},"기본-공격","기본 공격",[14,23,24],{},"기본 공격은 무기 종류에 따라 판정 범위와 속도가 달라집니다.",[26,27,28,47],"table",{},[29,30,31],"thead",{},[32,33,34,38,41,44],"tr",{},[35,36,37],"th",{},"무기 유형",[35,39,40],{},"공격 속도",[35,42,43],{},"범위",[35,45,46],{},"특이사항",[48,49,50,65,79,93],"tbody",{},[32,51,52,56,59,62],{},[53,54,55],"td",{},"한손검",[53,57,58],{},"빠름",[53,60,61],{},"근거리 단일",[53,63,64],{},"방패 병행 가능",[32,66,67,70,73,76],{},[53,68,69],{},"양손도끼",[53,71,72],{},"느림",[53,74,75],{},"근거리 광역",[53,77,78],{},"방어력 무시 일부 적용",[32,80,81,84,87,90],{},[53,82,83],{},"활",[53,85,86],{},"보통",[53,88,89],{},"원거리 단일",[53,91,92],{},"이동 중 공격 불가",[32,94,95,98,100,103],{},[53,96,97],{},"지팡이",[53,99,72],{},[53,101,102],{},"원거리 \u002F 광역",[53,104,105],{},"마나 소모 없음 (기본 공격 한정)",[18,107,109],{"id":108},"방어-메커니즘","방어 메커니즘",[14,111,112],{},"전투 중 피해를 줄이는 방법은 세 가지입니다.",[114,115,116,124,130],"ul",{},[117,118,119,123],"li",{},[120,121,122],"strong",{},"블록(Block):"," 방패 장착 시 활성화. 피해를 최대 80% 감소시키지만 이동이 불가합니다.",[117,125,126,129],{},[120,127,128],{},"회피(Dodge):"," 스태미나를 소모해 짧은 구르기를 실행합니다. 무적 판정 프레임이 존재합니다.",[117,131,132,135],{},[120,133,134],{},"저항(Resist):"," 속성 저항 수치가 높을수록 해당 속성 피해를 비율로 감소시킵니다.",[18,137,139],{"id":138},"스킬-시스템","스킬 시스템",[14,141,142],{},"캐릭터는 레벨업 시 스킬 포인트를 획득하며, 이를 스킬 트리에 투자합니다.",[144,145,147],"h3",{"id":146},"스킬-분류","스킬 분류",[114,149,150,156,162],{},[117,151,152,155],{},[120,153,154],{},"액티브 스킬:"," 직접 발동하며 쿨다운과 마나 비용이 있습니다.",[117,157,158,161],{},[120,159,160],{},"패시브 스킬:"," 항상 효과가 적용되며 스탯을 강화합니다.",[117,163,164,167],{},[120,165,166],{},"연계 스킬(체인):"," 특정 스킬 이후 연속으로 사용하면 강화 효과가 발동됩니다.",[144,169,171],{"id":170},"스킬-강화","스킬 강화",[14,173,174],{},"스킬 레벨은 1~5까지 올릴 수 있습니다. 레벨이 오를수록 피해량과 효과 지속 시간이 증가하지만, 마나 소모도 함께 늘어납니다.",[18,176,177],{"id":177},"상태이상",[14,179,180],{},"상태이상은 전투의 흐름을 크게 바꾸는 요소입니다. 보스 몬스터에게는 일부 상태이상이 저항되거나 지속 시간이 감소합니다.",[26,182,183,195],{},[29,184,185],{},[32,186,187,189,192],{},[35,188,177],{},[35,190,191],{},"효과",[35,193,194],{},"해제 방법",[48,196,197,208,219,230,241],{},[32,198,199,202,205],{},[53,200,201],{},"화상(Burn)",[53,203,204],{},"매 초 화염 피해, 방어력 감소",[53,206,207],{},"물 속성 스킬, 해독 물약",[32,209,210,213,216],{},[53,211,212],{},"빙결(Freeze)",[53,214,215],{},"이동 및 행동 불가",[53,217,218],{},"시간 경과 또는 화염 피해",[32,220,221,224,227],{},[53,222,223],{},"감전(Shock)",[53,225,226],{},"이동 속도 감소, 스킬 발동 실패 확률 부여",[53,228,229],{},"시간 경과",[32,231,232,235,238],{},[53,233,234],{},"출혈(Bleed)",[53,236,237],{},"매 초 고정 피해, 회복 효율 감소",[53,239,240],{},"붕대 사용, 성직자 치유 스킬",[32,242,243,246,249],{},[53,244,245],{},"공포(Fear)",[53,247,248],{},"무작위 방향으로 도주",[53,250,229],{},[252,253,254],"blockquote",{},[14,255,256,259],{},[120,257,258],{},"베타 변경 사항:"," 빙결 지속 시간이 v0.8.2 패치에서 기존 대비 20% 단축되었습니다.",[18,261,263],{"id":262},"관련-시스템","관련 시스템",[14,265,266,267,272],{},"전투 효율을 높이려면 ",[268,269,271],"a",{"href":270},"\u002Fsystems\u002Fprogression","성장과 레벨"," 가이드를 함께 참고하세요.",{"title":274,"searchDepth":275,"depth":275,"links":276},"",2,[277,278,279,284,285],{"id":20,"depth":275,"text":21},{"id":108,"depth":275,"text":109},{"id":138,"depth":275,"text":139,"children":280},[281,283],{"id":146,"depth":282,"text":147},3,{"id":170,"depth":282,"text":171},{"id":177,"depth":275,"text":177},{"id":262,"depth":275,"text":263},"일랜시아의 전투 메커니즘, 스킬 사용법, 상태이상 종류를 설명합니다.","md",{},{"title":290},"전투","\u002Fsystems\u002Fcombat",{"title":5,"description":286},"systems\u002Fcombat","vvYJ0o4_3QrXRcEv5eT-nBC5iJibzcEKftTpktP_QK4",1781586027155]