[{"data":1,"prerenderedAt":293},["ShallowReactive",2],{"page-\u002Fsystems\u002Feconomy":3},{"id":4,"title":5,"body":6,"description":284,"extension":285,"meta":286,"navigation":287,"path":289,"seo":290,"stem":291,"__hash__":292},"content\u002Fsystems\u002Feconomy.md","재화와 경제",{"type":7,"value":8,"toc":268},"minimark",[9,13,23,28,84,94,97,102,105,108,124,128,131,137,140,143,147,163,167,178,182,185,196,200,261],[10,11,5],"h1",{"id":12},"재화와-경제",[14,15,16,17,22],"p",{},"일랜시아의 경제 시스템은 플레이어 간 거래와 상점 시스템이 공존합니다. 재화를 효율적으로 관리하면 ",[18,19,21],"a",{"href":20},"\u002Fsystems\u002Fprogression","장비 강화","와 소모품 수급에 드는 비용을 크게 줄일 수 있습니다.",[24,25,27],"h2",{"id":26},"화폐-종류","화폐 종류",[29,30,31,47],"table",{},[32,33,34],"thead",{},[35,36,37,41,44],"tr",{},[38,39,40],"th",{},"화폐",[38,42,43],{},"획득 방법",[38,45,46],{},"주요 용도",[48,49,50,62,73],"tbody",{},[35,51,52,56,59],{},[53,54,55],"td",{},"골드(Gold)",[53,57,58],{},"몬스터 처치, 퀘스트, 아이템 판매",[53,60,61],{},"일반 상점 구매, 거래소 이용",[35,63,64,67,70],{},[53,65,66],{},"크레스트(Crest)",[53,68,69],{},"던전 클리어, 레이드 보상, 이벤트",[53,71,72],{},"희귀 장비, 외형 아이템, 보호석",[35,74,75,78,81],{},[53,76,77],{},"명성 포인트",[53,79,80],{},"길드 임무, 세력 퀘스트",[53,82,83],{},"세력 전용 상점, 칭호 해금",[85,86,87],"blockquote",{},[14,88,89,93],{},[90,91,92],"strong",{},"베타 안내:"," 크레스트는 정식 출시 시 현금 충전 연동 여부가 결정됩니다. 현재 베타에서는 인게임 전용입니다.",[24,95,96],{"id":96},"상점",[98,99,101],"h3",{"id":100},"일반-상점-npc-상점","일반 상점 (NPC 상점)",[14,103,104],{},"각 마을마다 기본 소모품과 초급 장비를 판매합니다. 가격은 고정이며 흥정이 불가합니다.",[14,106,107],{},"주요 판매 품목:",[109,110,111,115,118,121],"ul",{},[112,113,114],"li",{},"체력 물약 (소\u002F중\u002F대)",[112,116,117],{},"마나 물약 (소\u002F중\u002F대)",[112,119,120],{},"기본 강화석",[112,122,123],{},"귀환 스크롤",[98,125,127],{"id":126},"세력-상점","세력 상점",[14,129,130],{},"명성 포인트로 이용하는 특수 상점입니다. 각 세력 거점에 위치하며, 일반 상점에서 구매 불가능한 전용 아이템을 판매합니다.",[14,132,133,134],{},"세력 상점 접근 조건: 해당 세력 명성 ",[90,135,136],{},"500 이상",[24,138,139],{"id":139},"거래소",[14,141,142],{},"거래소는 플레이어 간 아이템을 사고파는 경매 방식의 시스템입니다.",[98,144,146],{"id":145},"이용-방법","이용 방법",[148,149,150,153,156],"ol",{},[112,151,152],{},"주요 도시의 거래소 NPC에게 접근합니다.",[112,154,155],{},"판매 시 아이템과 희망 가격을 등록합니다. 수수료는 거래 금액의 **5%**입니다.",[112,157,158,159,162],{},"등록 기간은 최대 ",[90,160,161],{},"72시간","이며 미판매 시 아이템이 반환됩니다.",[98,164,166],{"id":165},"시세-파악-팁","시세 파악 팁",[109,168,169,172,175],{},[112,170,171],{},"같은 아이템의 최근 거래 내역을 확인해 적정 가격을 파악하세요.",[112,173,174],{},"주말과 대규모 업데이트 직후에는 소모품 수요가 높아져 가격이 오르는 경향이 있습니다.",[112,176,177],{},"강화 재료(강화석, 보호석)는 강화 이벤트 기간에 가격이 급등합니다.",[98,179,181],{"id":180},"거래소-제한-아이템","거래소 제한 아이템",[14,183,184],{},"일부 아이템은 귀속(Bound) 속성으로 거래소 등록이 불가합니다.",[109,186,187,190,193],{},[112,188,189],{},"레이드 전용 장비",[112,191,192],{},"퀘스트 보상 아이템",[112,194,195],{},"크레스트로 구매한 외형 아이템",[24,197,199],{"id":198},"골드-획득-효율-비교","골드 획득 효율 비교",[29,201,202,215],{},[32,203,204],{},[35,205,206,209,212],{},[38,207,208],{},"활동",[38,210,211],{},"시간당 예상 골드",[38,213,214],{},"비고",[48,216,217,228,239,250],{},[35,218,219,222,225],{},[53,220,221],{},"일반 사냥 (레벨 적정)",[53,223,224],{},"3,000~6,000",[53,226,227],{},"드롭 아이템 판매 포함",[35,229,230,233,236],{},[53,231,232],{},"던전 클리어 (5인 파티)",[53,234,235],{},"8,000~15,000",[53,237,238],{},"보스 드롭 포함",[35,240,241,244,247],{},[53,242,243],{},"일일 임무 전체 완료",[53,245,246],{},"5,000~7,000",[53,248,249],{},"하루 1회 한정",[35,251,252,255,258],{},[53,253,254],{},"거래소 아이템 판매",[53,256,257],{},"변동",[53,259,260],{},"시세에 따라 큰 차이",[14,262,263,264,267],{},"재화를 바탕으로 장비를 효율적으로 강화하는 방법은 ",[18,265,266],{"href":20},"성장과 레벨","을 참고하세요.",{"title":269,"searchDepth":270,"depth":270,"links":271},"",2,[272,273,278,283],{"id":26,"depth":270,"text":27},{"id":96,"depth":270,"text":96,"children":274},[275,277],{"id":100,"depth":276,"text":101},3,{"id":126,"depth":276,"text":127},{"id":139,"depth":270,"text":139,"children":279},[280,281,282],{"id":145,"depth":276,"text":146},{"id":165,"depth":276,"text":166},{"id":180,"depth":276,"text":181},{"id":198,"depth":270,"text":199},"일랜시아의 화폐 종류, 상점 이용법, 거래소 운영 방식을 설명합니다.","md",{},{"title":288},"경제","\u002Fsystems\u002Feconomy",{"title":5,"description":284},"systems\u002Feconomy","7ukJNB0puBsBA39wbHOM3lmNk9Zq5aFIU3Fsxs2GXBM",1781586027155]