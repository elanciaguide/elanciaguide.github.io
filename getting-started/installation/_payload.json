[{"data":1,"prerenderedAt":277},["ShallowReactive",2],{"page-\u002Fgetting-started\u002Finstallation":3},{"id":4,"title":5,"body":6,"description":269,"extension":270,"meta":271,"navigation":272,"path":273,"seo":274,"stem":275,"__hash__":276},"content\u002Fgetting-started\u002Finstallation.md","설치 및 접속",{"type":7,"value":8,"toc":259},"minimark",[9,13,18,22,111,117,121,142,150,154,157,175,179,210,213,217,220,237,241,247,253],[10,11,5],"h1",{"id":12},"설치-및-접속",[14,15,17],"h2",{"id":16},"시스템-요구-사항","시스템 요구 사항",[19,20,21],"p",{},"게임 설치 전 PC 사양을 확인하세요.",[23,24,25,41],"table",{},[26,27,28],"thead",{},[29,30,31,35,38],"tr",{},[32,33,34],"th",{},"항목",[32,36,37],{},"최소 사양",[32,39,40],{},"권장 사양",[42,43,44,56,67,78,89,100],"tbody",{},[29,45,46,50,53],{},[47,48,49],"td",{},"OS",[47,51,52],{},"Windows 10 64-bit",[47,54,55],{},"Windows 11 64-bit",[29,57,58,61,64],{},[47,59,60],{},"CPU",[47,62,63],{},"Intel Core i5-8세대",[47,65,66],{},"Intel Core i7-10세대 이상",[29,68,69,72,75],{},[47,70,71],{},"RAM",[47,73,74],{},"8 GB",[47,76,77],{},"16 GB",[29,79,80,83,86],{},[47,81,82],{},"GPU",[47,84,85],{},"GTX 1060 6GB",[47,87,88],{},"RTX 3060 이상",[29,90,91,94,97],{},[47,92,93],{},"저장 공간",[47,95,96],{},"30 GB",[47,98,99],{},"50 GB (SSD 권장)",[29,101,102,105,108],{},[47,103,104],{},"네트워크",[47,106,107],{},"10 Mbps",[47,109,110],{},"50 Mbps 이상",[112,113,114],"blockquote",{},[19,115,116],{},"베타 테스트 기간 중 사양 요구치가 변동될 수 있습니다.",[14,118,120],{"id":119},"클라이언트-다운로드","클라이언트 다운로드",[122,123,124,128,136,139],"ol",{},[125,126,127],"li",{},"공식 홈페이지(elancia.game)에 접속합니다.",[125,129,130,131,135],{},"상단 메뉴에서 ",[132,133,134],"strong",{},"다운로드"," 버튼을 클릭합니다.",[125,137,138],{},"운영체제에 맞는 설치 파일을 내려받습니다.",[125,140,141],{},"다운로드 완료 후 설치 파일을 실행하고 안내에 따라 설치를 진행합니다.",[19,143,144,145,149],{},"설치 경로는 공백이 없는 경로를 권장합니다. (예: ",[146,147,148],"code",{},"C:\\Games\\Elancia",")",[14,151,153],{"id":152},"계정-생성","계정 생성",[19,155,156],{},"클라이언트 설치 후 공식 홈페이지에서 계정을 만들어야 합니다.",[122,158,159,166,169,172],{},[125,160,161,162,165],{},"홈페이지 우측 상단 ",[132,163,164],{},"회원가입","을 클릭합니다.",[125,167,168],{},"이메일 주소, 아이디, 비밀번호를 입력합니다.",[125,170,171],{},"이메일로 발송된 인증 메일을 확인하고 링크를 클릭하여 인증을 완료합니다.",[125,173,174],{},"베타 테스트 참가 신청이 승인된 계정만 접속이 가능합니다. 미승인 계정은 접속 시 안내 메시지가 표시됩니다.",[14,176,178],{"id":177},"런처-실행-및-서버-접속","런처 실행 및 서버 접속",[122,180,181,188,195,198,204],{},[125,182,183,184,187],{},"설치된 ",[132,185,186],{},"Elancia Launcher","를 실행합니다.",[125,189,190,191,194],{},"가입한 계정의 아이디와 비밀번호를 입력하고 ",[132,192,193],{},"로그인","합니다.",[125,196,197],{},"런처가 최신 패치를 자동으로 다운로드합니다. 업데이트가 완료될 때까지 기다립니다.",[125,199,200,203],{},[132,201,202],{},"게임 시작"," 버튼을 클릭하면 서버 선택 화면이 열립니다.",[125,205,206,207,165],{},"원하는 서버를 선택한 뒤 ",[132,208,209],{},"접속",[19,211,212],{},"베타 기간에는 단일 서버로 운영될 수 있습니다. 서버 목록은 테스트 일정에 따라 변경됩니다.",[14,214,216],{"id":215},"캐릭터-생성","캐릭터 생성",[19,218,219],{},"서버 접속 후 캐릭터 생성 화면이 표시됩니다.",[221,222,223,226,229,232],"ul",{},[125,224,225],{},"직업(클래스)을 선택합니다. 베타 테스트에서는 일부 직업만 개방되어 있을 수 있습니다.",[125,227,228],{},"외형(얼굴형, 헤어스타일, 체형 등)을 자유롭게 설정합니다.",[125,230,231],{},"캐릭터 이름을 입력합니다. 이름은 서버 내 중복이 허용되지 않습니다.",[125,233,234,236],{},[132,235,216],{}," 버튼을 클릭하면 게임이 시작됩니다.",[14,238,240],{"id":239},"자주-발생하는-문제","자주 발생하는 문제",[19,242,243,246],{},[132,244,245],{},"\"서버 점검 중\" 메시지가 표시될 때","\n베타 테스트 기간에는 정기 점검이 잦습니다. 공식 디스코드나 홈페이지 공지를 확인하세요.",[19,248,249,252],{},[132,250,251],{},"클라이언트 실행 오류(오류 코드: xxxx)","\n런처를 관리자 권한으로 실행해 보세요. 문제가 지속되면 클라이언트를 완전히 삭제 후 재설치합니다.",[19,254,255,258],{},[132,256,257],{},"패치 다운로드가 멈출 때","\n백신 프로그램이 파일을 차단하는 경우가 있습니다. 게임 설치 폴더를 백신 예외 경로에 추가하세요.",{"title":260,"searchDepth":261,"depth":261,"links":262},"",2,[263,264,265,266,267,268],{"id":16,"depth":261,"text":17},{"id":119,"depth":261,"text":120},{"id":152,"depth":261,"text":153},{"id":177,"depth":261,"text":178},{"id":215,"depth":261,"text":216},{"id":239,"depth":261,"text":240},"일랜시아 클라이언트 설치, 계정 생성, 서버 접속까지 단계별 안내입니다.","md",{},{"title":5},"\u002Fgetting-started\u002Finstallation",{"title":5,"description":269},"getting-started\u002Finstallation","cvRjI6_7qDkQAYWnLIYma9unRXwxsycFmIkSKoZDIvE",1781586027146]