[{"data":1,"prerenderedAt":118},["ShallowReactive",2],{"page-\u002Fgetting-started":3},{"id":4,"title":5,"body":6,"description":109,"extension":110,"meta":111,"navigation":112,"path":114,"seo":115,"stem":116,"__hash__":117},"content\u002Fgetting-started\u002Findex.md","입문 가이드",{"type":7,"value":8,"toc":102},"minimark",[9,13,17,23,28,31,48,52,95,99],[10,11,5],"h1",{"id":12},"입문-가이드",[14,15,16],"p",{},"일랜시아(Elancia)에 오신 것을 환영합니다. 이 카테고리는 게임을 처음 접하는 분들이 빠르게 적응할 수 있도록 클라이언트 설치부터 기본 조작까지 단계별로 안내합니다.",[18,19,20],"blockquote",{},[14,21,22],{},"현재 베타 테스트 단계입니다. 일부 기능이나 UI는 정식 출시 전 변경될 수 있습니다.",[24,25,27],"h2",{"id":26},"시작-순서","시작 순서",[14,29,30],{},"처음 일랜시아를 시작한다면 아래 순서를 따르세요.",[32,33,34,42],"ol",{},[35,36,37,41],"li",{},[38,39,40],"strong",{},"클라이언트 설치 및 계정 생성"," — 게임 클라이언트를 내려받고 계정을 만든 뒤 서버에 접속합니다.",[35,43,44,47],{},[38,45,46],{},"기본 조작 익히기"," — 캐릭터 이동, 카메라 조작, 단축키 등 핵심 조작을 숙지합니다.",[24,49,51],{"id":50},"문서-목록","문서 목록",[53,54,55,68],"table",{},[56,57,58],"thead",{},[59,60,61,65],"tr",{},[62,63,64],"th",{},"문서",[62,66,67],{},"내용",[69,70,71,84],"tbody",{},[59,72,73,81],{},[74,75,76],"td",{},[77,78,80],"a",{"href":79},"\u002Fgetting-started\u002Finstallation","설치 및 접속",[74,82,83],{},"클라이언트 설치, 계정 생성, 서버 접속 방법",[59,85,86,92],{},[74,87,88],{},[77,89,91],{"href":90},"\u002Fgetting-started\u002Fbasics","기본 조작과 UI",[74,93,94],{},"이동, 카메라, 단축키, 인터페이스 구성",[24,96,98],{"id":97},"베타-테스트-참여-안내","베타 테스트 참여 안내",[14,100,101],{},"일랜시아는 현재 베타 테스트 중입니다. 플레이 중 버그나 불편한 점은 공식 디스코드 또는 게임 내 피드백 채널을 통해 제보해 주세요. 여러분의 피드백이 게임을 더 나은 방향으로 만드는 데 큰 도움이 됩니다.",{"title":103,"searchDepth":104,"depth":104,"links":105},"",2,[106,107,108],{"id":26,"depth":104,"text":27},{"id":50,"depth":104,"text":51},{"id":97,"depth":104,"text":98},"일랜시아를 처음 시작하는 플레이어를 위한 입문 안내 모음입니다.","md",{},{"title":113},"입문","\u002Fgetting-started",{"title":5,"description":109},"getting-started\u002Findex","AOGE5asZelHlvb6R6k8C37qDCvm4oUeb7_bb8C2ziHI",1781586027056]