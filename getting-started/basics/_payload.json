[{"data":1,"prerenderedAt":468},["ShallowReactive",2],{"page-\u002Fgetting-started\u002Fbasics":3},{"id":4,"title":5,"body":6,"description":459,"extension":460,"meta":461,"navigation":462,"path":464,"seo":465,"stem":466,"__hash__":467},"content\u002Fgetting-started\u002Fbasics.md","기본 조작과 UI",{"type":7,"value":8,"toc":439},"minimark",[9,13,18,22,58,62,122,129,133,138,212,215,290,294,356,365,369,372,376,390,394,405,409,415,419,422,426,429,433],[10,11,5],"h1",{"id":12},"기본-조작과-ui",[14,15,17],"h2",{"id":16},"캐릭터-이동","캐릭터 이동",[19,20,21],"p",{},"일랜시아는 키보드와 마우스를 조합하여 캐릭터를 조작합니다.",[23,24,25,33,36,42,48],"ul",{},[26,27,28,32],"li",{},[29,30,31],"strong",{},"WASD"," 또는 방향키로 캐릭터를 이동합니다.",[26,34,35],{},"마우스 우클릭을 누른 채 드래그하면 시점(카메라)이 회전합니다.",[26,37,38,41],{},[29,39,40],{},"Shift","를 누른 채 이동하면 달리기(스프린트) 상태가 됩니다. 스태미나를 소모하므로 주의하세요.",[26,43,44,47],{},[29,45,46],{},"Space","를 누르면 점프합니다. 일부 지형에서는 이중 점프가 가능합니다.",[26,49,50,53,54,57],{},[29,51,52],{},"Ctrl + 방향키"," 또는 ",[29,55,56],{},"Alt를 누른 채 클릭","하면 해당 지점으로 자동 이동합니다.",[14,59,61],{"id":60},"카메라-조작","카메라 조작",[63,64,65,78],"table",{},[66,67,68],"thead",{},[69,70,71,75],"tr",{},[72,73,74],"th",{},"동작",[72,76,77],{},"방법",[79,80,81,90,98,111],"tbody",{},[69,82,83,87],{},[84,85,86],"td",{},"시점 회전",[84,88,89],{},"마우스 우클릭 드래그",[69,91,92,95],{},[84,93,94],{},"줌 인 \u002F 아웃",[84,96,97],{},"마우스 휠 스크롤",[69,99,100,103],{},[84,101,102],{},"1인칭 전환",[84,104,105,106,110],{},"마우스 휠 최대 줌 인 또는 ",[107,108,109],"code",{},"V"," 키",[69,112,113,116],{},[84,114,115],{},"카메라 초기화",[84,117,118,121],{},[107,119,120],{},"R"," 키 (캐릭터 뒤로 정렬)",[19,123,124,125,128],{},"카메라와 캐릭터 이동 방향이 연동되어 있어, 카메라를 돌리면 ",[107,126,127],{},"W"," 키의 전진 방향도 함께 바뀝니다.",[14,130,132],{"id":131},"기본-단축키","기본 단축키",[134,135,137],"h3",{"id":136},"캐릭터-상태","캐릭터 \u002F 상태",[63,139,140,150],{},[66,141,142],{},[69,143,144,147],{},[72,145,146],{},"단축키",[72,148,149],{},"기능",[79,151,152,162,172,182,192,202],{},[69,153,154,159],{},[84,155,156],{},[107,157,158],{},"P",[84,160,161],{},"캐릭터 정보 창 열기",[69,163,164,169],{},[84,165,166],{},[107,167,168],{},"I",[84,170,171],{},"인벤토리 열기",[69,173,174,179],{},[84,175,176],{},[107,177,178],{},"K",[84,180,181],{},"스킬 창 열기",[69,183,184,189],{},[84,185,186],{},[107,187,188],{},"Q",[84,190,191],{},"퀘스트 일지 열기",[69,193,194,199],{},[84,195,196],{},[107,197,198],{},"M",[84,200,201],{},"지도 열기",[69,203,204,209],{},[84,205,206],{},[107,207,208],{},"B",[84,210,211],{},"장비 창 열기",[134,213,214],{"id":214},"전투",[63,216,217,225],{},[66,218,219],{},[69,220,221,223],{},[72,222,146],{},[72,224,149],{},[79,226,227,235,249,260,270,280],{},[69,228,229,232],{},[84,230,231],{},"마우스 좌클릭",[84,233,234],{},"기본 공격 \u002F NPC 상호작용",[69,236,237,246],{},[84,238,239,242,243],{},[107,240,241],{},"1"," ~ ",[107,244,245],{},"0",[84,247,248],{},"스킬 슬롯 1~10 사용",[69,250,251,257],{},[84,252,253,256],{},[107,254,255],{},"`"," (백틱)",[84,258,259],{},"스킬 슬롯 확장 바 토글",[69,261,262,267],{},[84,263,264],{},[107,265,266],{},"Tab",[84,268,269],{},"가장 가까운 적 자동 타겟",[69,271,272,277],{},[84,273,274],{},[107,275,276],{},"F",[84,278,279],{},"타겟 해제",[69,281,282,287],{},[84,283,284],{},[107,285,286],{},"T",[84,288,289],{},"보조 타겟 고정 (파티원 등)",[134,291,293],{"id":292},"편의-기능","편의 기능",[63,295,296,304],{},[66,297,298],{},[69,299,300,302],{},[72,301,146],{},[72,303,149],{},[79,305,306,316,326,336,346],{},[69,307,308,313],{},[84,309,310],{},[107,311,312],{},"Enter",[84,314,315],{},"채팅 창 활성화",[69,317,318,323],{},[84,319,320],{},[107,321,322],{},"Esc",[84,324,325],{},"메뉴 닫기 \u002F 취소",[69,327,328,333],{},[84,329,330],{},[107,331,332],{},"PrintScreen",[84,334,335],{},"스크린샷 저장",[69,337,338,343],{},[84,339,340],{},[107,341,342],{},"Alt + Enter",[84,344,345],{},"전체화면 \u002F 창모드 전환",[69,347,348,353],{},[84,349,350],{},[107,351,352],{},"F10",[84,354,355],{},"UI 전체 숨기기 (스크린샷용)",[357,358,359],"blockquote",{},[19,360,361,362,364],{},"단축키는 설정 창(",[107,363,322],{}," → 단축키 설정)에서 원하는 키로 변경할 수 있습니다.",[14,366,368],{"id":367},"화면-인터페이스ui-구성","화면 인터페이스(UI) 구성",[19,370,371],{},"게임 화면은 크게 다섯 영역으로 나뉩니다.",[134,373,375],{"id":374},"_1-상태-바-화면-좌측-상단","1. 상태 바 (화면 좌측 상단)",[19,377,378,379,382,383,382,386,389],{},"현재 캐릭터의 ",[29,380,381],{},"HP(체력)",", ",[29,384,385],{},"MP(마나)",[29,387,388],{},"스태미나"," 게이지가 표시됩니다. HP가 0이 되면 사망하며 가까운 부활 지점으로 이동합니다.",[134,391,393],{"id":392},"_2-미니맵-화면-우측-상단","2. 미니맵 (화면 우측 상단)",[19,395,396,397,400,401,404],{},"현재 위치와 주변 지형, NPC, 파티원의 위치가 표시됩니다. 미니맵 우측의 ",[107,398,399],{},"+"," \u002F ",[107,402,403],{},"-"," 버튼으로 축척을 조절할 수 있습니다.",[134,406,408],{"id":407},"_3-스킬-바-화면-하단-중앙","3. 스킬 바 (화면 하단 중앙)",[19,410,411,412,414],{},"사용 가능한 스킬을 슬롯에 등록하여 단축키로 사용합니다. 슬롯에 스킬을 배치하려면 스킬 창(",[107,413,178],{},")에서 원하는 스킬을 슬롯으로 드래그하세요.",[134,416,418],{"id":417},"_4-퀘스트-트래커-화면-우측","4. 퀘스트 트래커 (화면 우측)",[19,420,421],{},"현재 진행 중인 퀘스트의 목표가 실시간으로 표시됩니다. 항목을 클릭하면 목표 위치로 자동 이동합니다.",[134,423,425],{"id":424},"_5-채팅-창-화면-좌측-하단","5. 채팅 창 (화면 좌측 하단)",[19,427,428],{},"전체 채팅, 파티 채팅, 시스템 메시지 등이 탭으로 구분되어 표시됩니다. 탭을 우클릭하면 채널별 표시 여부를 설정할 수 있습니다.",[14,430,432],{"id":431},"다음-단계","다음 단계",[19,434,435,436,438],{},"기본 조작에 익숙해졌다면 퀘스트를 통해 본격적으로 게임을 진행해 보세요. 메인 퀘스트는 ",[107,437,188],{}," 키로 퀘스트 일지를 열어 확인할 수 있습니다.",{"title":440,"searchDepth":441,"depth":441,"links":442},"",2,[443,444,445,451,458],{"id":16,"depth":441,"text":17},{"id":60,"depth":441,"text":61},{"id":131,"depth":441,"text":132,"children":446},[447,449,450],{"id":136,"depth":448,"text":137},3,{"id":214,"depth":448,"text":214},{"id":292,"depth":448,"text":293},{"id":367,"depth":441,"text":368,"children":452},[453,454,455,456,457],{"id":374,"depth":448,"text":375},{"id":392,"depth":448,"text":393},{"id":407,"depth":448,"text":408},{"id":417,"depth":448,"text":418},{"id":424,"depth":448,"text":425},{"id":431,"depth":441,"text":432},"일랜시아의 캐릭터 이동, 카메라, 단축키, 화면 인터페이스 구성을 안내합니다.","md",{},{"title":463},"기본 조작","\u002Fgetting-started\u002Fbasics",{"title":5,"description":459},"getting-started\u002Fbasics","Q1dvd7yuLybbjqM7QZo36jfSOuYCzIOJ2HZMITFRWfw",1781586027146]