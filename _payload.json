[{"data":1,"prerenderedAt":103},["ShallowReactive",2],{"page-\u002F":3},{"id":4,"title":5,"body":6,"description":94,"extension":95,"meta":96,"navigation":97,"path":99,"seo":100,"stem":101,"__hash__":102},"content\u002Findex.md","일랜시아 가이드",{"type":7,"value":8,"toc":89},"minimark",[9,14,23,38,41,45],[10,11,13],"h1",{"id":12},"일랜시아-가이드-project-er","일랜시아 가이드 — Project ER",[15,16,17,18,22],"p",{},"**일랜시아(Elancia)**는 중세 판타지 세계관의 MMORPG입니다. 본 프로젝트(가칭 ",[19,20,21],"strong",{},"Project ER",")는 넥슨 리플레이를 통해 일랜시아 IP 사용 계약을 맺고 새롭게 개발 중인 빌드이며, 현재 베타 테스트 단계로 콘텐츠와 시스템이 지속적으로 업데이트되고 있습니다.",[24,25,26],"blockquote",{},[15,27,28,31,32,37],{},[19,29,30],{},"베타 테스트 안내",": 현재 일랜시아는 베타 버전입니다. 게임 내 데이터는 정식 출시 시 초기화될 수 있으며, 가이드 내용은 패치에 따라 변경될 수 있습니다. 최신 변경사항은 ",[33,34,36],"a",{"href":35},"\u002Fboard\u002Fc\u002Fpatchnote","패치노트","에서 확인하세요.",[39,40],"hr",{},[42,43,44],"h2",{"id":44},"카테고리",[46,47,48,56,63,70,77,84],"ul",{},[49,50,51,55],"li",{},[33,52,54],{"href":53},"\u002Fgetting-started","입문 가이드"," — 처음 시작하는 플레이어를 위한 기초 안내",[49,57,58,62],{},[33,59,61],{"href":60},"\u002Fsystems","시스템"," — 전투, 성장, 제작, 거래 등 게임 시스템 상세 설명",[49,64,65,69],{},[33,66,68],{"href":67},"\u002Fdatabase","도감"," — 몬스터, 아이템, 스킬 데이터베이스",[49,71,72,76],{},[33,73,75],{"href":74},"\u002Ftools","도구"," — 빌드 계산기, 경험치 계산기 등 유틸리티",[49,78,79,83],{},[33,80,82],{"href":81},"\u002Ffaq","FAQ"," — 자주 묻는 질문과 답변",[49,85,86,88],{},[33,87,36],{"href":35}," — 베타 기간 업데이트 내역",{"title":90,"searchDepth":91,"depth":91,"links":92},"",2,[93],{"id":44,"depth":91,"text":44},"일랜시아(Project ER) 베타 공식 커뮤니티 가이드 — 입문부터 심화 공략까지","md",{},{"title":98},"홈","\u002F",{"title":5,"description":94},"index","y7zZgbPPgXokv14xMqngkZS4bjntztPOsL3mNMRQmfM",1781586026552]